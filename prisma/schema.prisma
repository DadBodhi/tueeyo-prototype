generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id             String           @id @default(cuid())
  title          String
  createdAt      DateTime         @default(now())
  band           String?
  cost           Float?
  deletedAt      DateTime?
  description    String?
  dj             String?
  end_datetime   DateTime?
  event_type     String?
  level_id       String?
  parentId       String?
  start_datetime DateTime?
  status         String           @default("draft")
  teacher        String?
  updatedAt      DateTime         @updatedAt
  venue_id       String?
  level          Level?           @relation(fields: [level_id], references: [id])
  parent         Event?           @relation("EventChildren", fields: [parentId], references: [id])
  children       Event[]          @relation("EventChildren")
  venue          Venue?           @relation(fields: [venue_id], references: [id])
  recurrence     EventRecurrence?
  styles         EventStyle[]
}

model EventStyle {
  id       String @id @default(cuid())
  event_id String
  style_id String
  event    Event  @relation(fields: [event_id], references: [id], onDelete: Cascade)
  style    Style  @relation(fields: [style_id], references: [id])

  @@unique([event_id, style_id])
}

model Style {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  events    EventStyle[]
}

model Level {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  events    Event[]
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  postcode  String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  events    Event[]
}

model EventRecurrence {
  id               String    @id @default(cuid())
  event_id         String    @unique
  frequency        String
  day_of_week      Int?
  week_of_month    Int?
  specific_date    Int?
  end_date         DateTime?
  occurrence_count Int?
  event            Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
}
